rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "traffagency0@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'businessName', 'type', 'createdAt']) &&
             data.keys().hasOnly(['name', 'businessName', 'phone', 'email', 'message', 'type', 'createdAt']) &&
             (data.keys().hasAny(['phone', 'email'])) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.businessName is string && data.businessName.size() >= 1 && data.businessName.size() <= 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 20)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000)) &&
             data.type in ['call', 'audit'] &&
             data.createdAt == request.time; // Enforce server timestamp
    }

    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
