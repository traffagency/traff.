{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential client who submitted a form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead" },
        "businessName": { "type": "string", "description": "Name of the lead's business" },
        "phone": { "type": "string", "description": "Phone number of the lead" },
        "message": { "type": "string", "description": "Message from the lead" },
        "type": { "type": "string", "enum": ["call", "audit"], "description": "Type of request" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was created" }
      },
      "required": ["name", "businessName", "phone", "type", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads from the website forms"
    }
  }
}
